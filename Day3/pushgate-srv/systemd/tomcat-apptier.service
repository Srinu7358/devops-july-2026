[Unit]
Description=Tomcat app-tier endpoints (push-gate lab)
After=network.target tomcat-webtier.service

[Service]
Type=forking
User=tomcat
Group=tomcat

Environment=JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
Environment=CATALINA_HOME=/opt/tomcat11
Environment=CATALINA_BASE=/srv/apptier
Environment=CATALINA_PID=/srv/apptier/temp/tomcat.pid

ExecStart=/opt/tomcat11/bin/catalina.sh start
ExecStop=/opt/tomcat11/bin/catalina.sh stop

[Install]
WantedBy=multi-user.target
